# Ghostrail — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed.

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# Default: 3000
PORT=3000

# ─── LLM Provider ────────────────────────────────────────────────────────────

# Groq API key.
# When set, Ghostrail uses the Groq provider (openai/gpt-oss-120b) — takes priority over OpenAI.
# Required for: AI-powered intent pack generation via Groq
GROQ_API_KEY=

# OpenAI API key.
# When set (and GROQ_API_KEY is unset), Ghostrail uses the OpenAI provider (gpt-4o).
# When both are unset, the heuristic (offline) provider is used instead.
OPENAI_API_KEY=

# OpenAI model override (optional).
# Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# ─── GitHub Integration ───────────────────────────────────────────────────────

# GitHub personal access token (classic) or fine-grained PAT.
# Required scopes: repo (for issue creation on private repos), public_repo (for public repos).
# This is the fallback when no token is provided in the request body.
# Required for: POST /api/intent-packs/:id/create-github-issue
GITHUB_TOKEN=
